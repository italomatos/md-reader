#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "md_reader"
require "launchy"
require "tmpdir"

if ARGV.empty?
  warn "Usage: md-reader <arquivo.md>"
  exit 1
end

file_path = ARGV[0]

unless File.exist?(file_path)
  warn "Erro: arquivo '#{file_path}' não encontrado."
  exit 1
end

unless File.readable?(file_path)
  warn "Erro: sem permissão para ler '#{file_path}'."
  exit 1
end

content = File.read(file_path, encoding: "utf-8")
title   = File.basename(file_path)
html    = MdReader::Converter.new.call(content, title)

basename_no_ext = File.basename(file_path, File.extname(file_path))
tmp_path = File.join(Dir.tmpdir, "md_reader_#{basename_no_ext}_#{Process.pid}.html")

File.write(tmp_path, html, encoding: "utf-8")
at_exit { File.delete(tmp_path) rescue nil }

puts "Abrindo #{title} no browser..."
Launchy.open("file://#{tmp_path}")

sleep 3
